generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String
  role          String         @default("VIEWER")
  avatar        String?
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activityLogs  ActivityLog[]
  blogPosts     BlogPost[]
  media         MediaFile[]
  notifications Notification[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
}

model Product {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String
  shortDescription     String
  categoryId           String
  images               String
  specifications       String
  isFeatured           Boolean  @default(false)
  isActive             Boolean  @default(true)
  tags                 String?
  variants             String?
  priceDisplay         Boolean  @default(true)
  minOrder             String?
  priceRange           String?
  tieredPricing        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ogImage              String?
  seoDescription       String?
  seoKeywords          String?
  seoTitle             String?
  sku                  String?
  additionalCategories String?
  category             Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  rfqs                 RFQ[]
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String
  excerpt        String?
  coverImage     String?
  tags           String?
  authorId       String
  isPublished    Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  author         User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model ContactInquiry {
  id              String   @id @default(cuid())
  name            String
  email           String
  company         String?
  phone           String?
  country         String?
  message         String
  productInterest String?
  status          String   @default("NEW")
  createdAt       DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  group String @default("general")
}

model RFQ {
  id                  String    @id @default(cuid())
  productId           String?
  productName         String?
  buyerName           String
  buyerEmail          String
  buyerCompany        String?
  buyerPhone          String?
  buyerCountry        String?
  quantity            Int
  targetPrice         String?
  deliveryDate        DateTime?
  shippingTo          String?
  specialRequirements String?
  status              String    @default("NEW")
  adminNotes          String?
  quotedPrice         String?
  quotedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  product             Product?  @relation(fields: [productId], references: [id])
}

model MenuItem {
  id           String     @id @default(cuid())
  menuLocation String     @default("main")
  label        String
  url          String
  target       String     @default("_self")
  icon         String?
  parentId     String?
  order        Int        @default(0)
  isMegaMenu   Boolean    @default(false)
  megaMenuData String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  parent       MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children     MenuItem[] @relation("MenuHierarchy")
}

model MediaFile {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  filePath     String
  fileSize     Int
  mimeType     String
  width        Int?
  height       Int?
  folder       String   @default("general")
  alt          String?
  uploadedBy   String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [uploadedBy], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Redirect {
  id         String   @id @default(cuid())
  sourceUrl  String   @unique
  targetUrl  String
  statusCode Int      @default(301)
  isActive   Boolean  @default(true)
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
}

model PopupBanner {
  id           String    @id @default(cuid())
  name         String
  content      String
  image        String?
  ctaText      String?
  ctaLink      String?
  trigger      String    @default("load")
  triggerValue String?
  displayPages String?
  showOnce     Boolean   @default(false)
  isActive     Boolean   @default(true)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())
}

model CustomForm {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String?
  fields         String
  submitEmail    String?
  successMessage String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  submissions    FormSubmission[]
}

model FormSubmission {
  id        String     @id @default(cuid())
  formId    String
  data      String
  ipAddress String?
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())
  form      CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
}
