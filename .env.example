# Database Configuration
# Using SQLite locally. For production (Hostinger VPS, etc.), change to PostgreSQL or MySQL
# Example: DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
DATABASE_URL="file:./dev.db"

# Next Auth Configuration
# NEXTAUTH_SECRET is required. Generate one securely using: openssl rand -base64 32
NEXTAUTH_SECRET="your_secure_generated_random_string_here_123!"
# The base URL of your application. E.g. https://www.globalstitch.com in production.
NEXTAUTH_URL="http://localhost:3000"

# Mailer / SMTP Configuration
# Required to send Outgoing Emails automatically upon Custom Form or RFQ submission
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="no-reply@yourdomain.com"
SMTP_PASSWORD="your_secure_smtp_password"
SMTP_FROM='"GlobalStitch System" <no-reply@yourdomain.com>'

# Tracking & Analytics (Optional, can also be configured inside Admin Dashboard)
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_FB_PIXEL_ID="123456789012345"

# File Upload Constraints
# Max image size limit
NEXT_PUBLIC_MAX_FILE_SIZE="5242880" # 5MB in bytes
